# Copy this file to .env and fill values locally.
# Never commit real API keys or cookies.

# PearlFortune wallet used by the miner and pool-stat lookups.
PRL_WALLET=prl1...

# Salad API keys.
SALAD_API_KEY_2=
SALAD_API_KEY_KRY1=

# Optional runtime paths.
SALAD_PRL_STATE_DIR=./state
SALAD_PRL_ENV=./.env

# Optional mode overrides.
PRL_FLEET_MODE=fill
PRL_FILL_FIXED_DECISION_PRICE_USD=0.64
PRL_OPTIMIZE_FIXED_DECISION_PRICE_USD=0.62
PRL_FILL_MIN_PROFIT_USD_DAY=0.05
PRL_NEGATIVE_SLOT_GRACE_SECONDS=90
PRL_OPTIMIZE_MIN_PROFIT_USD_DAY=0.01
PRL_OPTIMIZE_MIN_UPGRADE_DELTA_USD_DAY=0.25

# Pearl fee used by the deterministic scheduler.
# Normal conservative planning: 0.05.
# Current/temporary low-fee windows can use either direct override:
#   PRL_PEARL_FEE_RATE=0.01
# or an expiry-bound override:
#   PRL_TEMP_PEARL_FEE_RATE=0.01
#   PRL_TEMP_PEARL_FEE_UNTIL_UTC=2026-06-25T00:00:00+00:00
PRL_PEARL_FEE_RATE=0.05

# New scheduler mode config.
PRL_BASE_ALLOWED_PRIORITIES=batch
PRL_BOOST_ALLOWED_PRIORITIES=batch,low
PRL_BOOST_TRAILING_MIN_30M_USD=0.70
PRL_AGGRESSIVE_TRAILING_MIN_1H_USD=0.72
PRL_RISK_OFF_TRAILING_MIN_15M_USD=0.68
PRL_BOOST_MIN_WINDOW_SECONDS=1200
PRL_AGGRESSIVE_MIN_WINDOW_SECONDS=2700
PRL_NO_GPU_SLEEP_AFTER_SECONDS=3600
PRL_NO_GPU_SLEEP_SECONDS=900
PRL_SALAD_API_MAX_REQUESTS_PER_MINUTE=120

# Optional JSON config for adding more 10-slot organizations.
# Keep API key values private; only put env var names here.
# Use EXTRA to append to the default orgs. Use SALAD_FLEET_ORGS_JSON only when
# you intentionally want to replace the whole org list.
# SALAD_FLEET_EXTRA_ORGS_JSON='[{"label":"kray4","slug":"kray4","api_key_env":"SALAD_API_KEY_KRAY4","slot_prefix":"prl-kray4-roi","slots":10,"enabled":true}]'
# SALAD_API_KEY_KRAY4=
