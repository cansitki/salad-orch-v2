# Copy this file to .env and fill values locally.
# Never commit real API keys or cookies.

# PearlFortune wallet used by the miner and pool-stat lookups.
PRL_WALLET=prl1...

# Salad API keys.
SALAD_API_KEY_2=
SALAD_API_KEY_KRY1=
SALAD_API_KEY_KRY2=
SALAD_API_KEY_KR1=
SALAD_API_KEY_KR2=
SALAD_API_KEY_KR3=

# Optional Salad Portal login for private balance refreshes.
# Used only by scripts/portal_balances.py with a local cookie jar.
SALAD_PORTAL_EMAIL=
SALAD_PORTAL_PASSWORD=
SALAD_PORTAL_COOKIE_JAR=state/portal_cookies.txt

# Optional runtime paths.
SALAD_PRL_STATE_DIR=./state
SALAD_PRL_ENV=./.env

# Optional mode overrides.
PRL_FLEET_MODE=fill
PRL_FILL_FIXED_DECISION_PRICE_USD=0.64
PRL_OPTIMIZE_FIXED_DECISION_PRICE_USD=0.62
PRL_FILL_MIN_PROFIT_USD_DAY=0.30
PRL_NEGATIVE_SLOT_GRACE_SECONDS=90
PRL_GUARD_NOHASH_GRACE_SECONDS=60
PRL_GUARD_NEGATIVE_GRACE_SECONDS=120
PRL_GUARD_RETARGET_COOLDOWN_SECONDS=120
PRL_PENDING_STATUS_RETARGET_AFTER_SECONDS=180
PRL_OPTIMIZE_MIN_PROFIT_USD_DAY=0.01
PRL_OPTIMIZE_MIN_UPGRADE_DELTA_USD_DAY=0.25

# Optional payout-reality discount applied to pool reward-per-TH estimates.
# Use values below 1.0 when actual credited+pending PRL trails reported-hashrate estimates.
PRL_REWARD_CALIBRATION_FACTOR=1.0

# Pearl fee used by the deterministic scheduler.
# Normal conservative planning: 0.05.
# Current/temporary low-fee windows can use either direct override:
#   PRL_PEARL_FEE_RATE=0.01
# or an expiry-bound override:
#   PRL_TEMP_PEARL_FEE_RATE=0.01
#   PRL_TEMP_PEARL_FEE_UNTIL_UTC=2026-06-25T00:00:00+00:00
PRL_PEARL_FEE_RATE=0.05

# New scheduler mode config.
PRL_BASE_ALLOWED_PRIORITIES=batch,low
PRL_BOOST_ALLOWED_PRIORITIES=batch,low
PRL_BOOST_TRAILING_MIN_30M_USD=0.70
PRL_AGGRESSIVE_TRAILING_MIN_1H_USD=0.72
PRL_RISK_OFF_TRAILING_MIN_15M_USD=0.68
PRL_BOOST_MIN_WINDOW_SECONDS=1200
PRL_AGGRESSIVE_MIN_WINDOW_SECONDS=2700
PRL_NO_GPU_SLEEP_AFTER_SECONDS=3600
PRL_NO_GPU_SLEEP_SECONDS=900
PRL_AVAILABILITY_STALE_AFTER_SECONDS=1800
PRL_SALAD_API_MAX_REQUESTS_PER_MINUTE=120

# Spike history safety. Guard writes negative/no-hash slot spikes; spike_report
# summarizes 30/60 minute windows and can cooldown unstable profiles fleet-wide.
PRL_SPIKE_PROFILE_30M_THRESHOLD=3
PRL_SPIKE_PROFILE_60M_THRESHOLD=5
PRL_SPIKE_PROFILE_AFFECTED_SLOTS_60M_THRESHOLD=3
PRL_SPIKE_AUTO_COOLDOWN_PROFILES=1
PRL_SPIKE_PROFILE_COOLDOWN_SECONDS=3600
PRL_SPIKE_COOLDOWN_SCAN_LIMIT=1000

# Optional JSON config for adding more 10-slot organizations.
# Keep API key values private; only put env var names here.
# Use EXTRA to append to the default orgs. Use SALAD_FLEET_ORGS_JSON only when
# you intentionally want to replace the whole org list.
# Example: append the next 60 slots. Keep key values private.
# If kry2 shares kry1's actual Salad key, keep api_key_env=SALAD_API_KEY_KRY1 so API budgeting is shared.
# If alpha1 and alpha2 share one actual Salad key, keep both on SALAD_API_KEY_ALPHA.
# SALAD_FLEET_EXTRA_ORGS_JSON='[{"label":"kry2","slug":"kry2","api_key_env":"SALAD_API_KEY_KRY1","slot_prefix":"prl-kry2-roi","worker_prefix":"kry2-prl","worker_slot_prefix":"kry2-roi-","pool_worker_prefix":"kry2-prl-kry2","display_prefix":"PearlFortune KRY2","slots":10,"enabled":true},{"label":"kr1","slug":"kr1","api_key_env":"SALAD_API_KEY_KR1","slot_prefix":"prl-kr1-roi","worker_prefix":"kr1-prl","worker_slot_prefix":"kr1-roi-","pool_worker_prefix":"kr1-prl-kr1","display_prefix":"PearlFortune KR1","slots":10,"enabled":true},{"label":"kr2","slug":"kr2","api_key_env":"SALAD_API_KEY_KR1","slot_prefix":"prl-kr2-roi","worker_prefix":"kr2-prl","worker_slot_prefix":"kr2-roi-","pool_worker_prefix":"kr2-prl-kr2","display_prefix":"PearlFortune KR2","slots":10,"enabled":true},{"label":"kr3","slug":"kr3","api_key_env":"SALAD_API_KEY_KR1","slot_prefix":"prl-kr3-roi","worker_prefix":"kr3-prl","worker_slot_prefix":"kr3-roi-","pool_worker_prefix":"kr3-prl-kr3","display_prefix":"PearlFortune KR3","slots":10,"enabled":true},{"label":"alpha1","slug":"alpha1","api_key_env":"SALAD_API_KEY_ALPHA","slot_prefix":"prl-alpha1-roi","worker_prefix":"alpha1-prl","worker_slot_prefix":"alpha1-roi-","pool_worker_prefix":"alpha1-prl-alpha1","display_prefix":"PearlFortune ALPHA1","slots":10,"enabled":true},{"label":"alpha2","slug":"alpha2","api_key_env":"SALAD_API_KEY_ALPHA","slot_prefix":"prl-alpha2-roi","worker_prefix":"alpha2-prl","worker_slot_prefix":"alpha2-roi-","pool_worker_prefix":"alpha2-prl-alpha2","display_prefix":"PearlFortune ALPHA2","slots":10,"enabled":true}]'
